{
  "name": "test-chat",
  "version": "1.0.0",
  "description": "A minimal web app providing a chat interface to GitHub Copilot via @github/copilot-sdk",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx tsx server.ts",
    "test": "npx tsx test.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:prod": "npx playwright test --project=prod",
    "test:e2e:local": "npx playwright test --project=local"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.31",
    "dotenv": "^17.3.1",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "overrides": {}
}
