# GitHub Personal Access Token with Copilot access
# Optional: used as server-side fallback for testing/CI
# Users provide their own token via the web UI
COPILOT_GITHUB_TOKEN=

# Server port (optional, defaults to 3000)
PORT=3000

# Azure Storage account name (optional)
# When set, session data persists to Azure Table Storage + Blob Storage
# Authentication uses managed identity (DefaultAzureCredential)
# When empty, sessions are stored in-memory only (lost on restart)
AZURE_STORAGE_ACCOUNT_NAME=
